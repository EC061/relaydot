# Generate with: openssl rand -base64 32
RELAYDOT_ADMIN_TOKEN=change-me-before-starting
# Keep loopback when a reverse proxy runs on the host. Change deliberately for
# direct LAN access and firewall the port.
RELAYDOT_BIND_ADDRESS=127.0.0.1
RELAYDOT_PORT=3000
RELAYDOT_IMAGE=ghcr.io/ec061/relaydot-controller:latest
